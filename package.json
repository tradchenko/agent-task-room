{
  "name": "agent-task-room",
  "version": "0.1.0",
  "description": "Общая task-room сессия для совместного обсуждения задач и аудита между агентами с разным контекстом.",
  "type": "module",
  "bin": {
    "agent-task-room": "dist/bin/agent-task-room.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tradchenko/agent-task-room.git"
  },
  "homepage": "https://github.com/tradchenko/agent-task-room#readme",
  "bugs": {
    "url": "https://github.com/tradchenko/agent-task-room/issues"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "cli": "node dist/bin/agent-task-room.js",
    "server": "node dist/server/index.js",
    "check": "npm run compile && vitest run && playwright test",
    "doctor": "npm run compile && node dist/bin/agent-task-room.js doctor",
    "link:local": "npm run compile && npm link",
    "prepublishOnly": "npm run check && npm run compile",
    "test": "npm run compile && vitest run",
    "test:e2e": "npm run compile && playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:watch": "vitest"
  },
  "keywords": [
    "agents",
    "mcp",
    "audit",
    "collaboration",
    "task-room"
  ],
  "author": "Timur Tradchenko",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
